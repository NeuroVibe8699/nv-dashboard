{
  "version": 2,
  "public": true,
  "buildCommand": "cd artifacts/neurovibe-dashboard && npm install && npm run build",
  "outputDirectory": "artifacts/neurovibe-dashboard/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/neurovibe-dashboard/dist/$1",
      "continue": true
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/neurovibe-dashboard/dist/index.html"
    }
  ]
}
